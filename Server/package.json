{
  "name": "task-manager-server",
  "version": "1.0.0",
  "description": "Express backend for Task Manager",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "server": "nodemon --signal SIGTERM server.js",
    "start": "node server.js"
  },
  "nodemonConfig": {
    "delay": 1000,
    "watch": ["server.js", "controllers", "routes", "middleware", "config", "models"],
    "ext": "js,json"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@google/generative-ai": "^0.21.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.7",
    "sequelize": "^6.37.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}

